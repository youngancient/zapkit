{
  "name": "zap",
  "version": "0.1.0",
  "description": "TypeScript SDK Scaffold",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "sdk",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@rsksmart/bridges-core-sdk": "^0.5.0",
    "@rsksmart/flyover-sdk": "^1.8.0",
    "@rsksmart/rsk-swap-sdk": "^1.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
